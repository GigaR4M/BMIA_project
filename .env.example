# .env.example — Variáveis de ambiente do Bot BMIA
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=seu_token_aqui

# ── Google Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_CHAT_API_KEY=sua_chave_gemini_chat_aqui   # opcional, usa GEMINI_API_KEY se vazio
GEMINI_CHAT_MODEL=gemini-2.5-flash                # modelo padrão para chat
GEMINI_MODERATION_MODEL=gemini-2.5-flash    # modelo padrão para moderação

# ── Banco de Dados (Supabase PostgreSQL) ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Telegram (opcional) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_token_telegram
TELEGRAM_CHAT_ID=seu_chat_id

# ── Canais e Cargos Padrão (fallback enquanto guild_settings não está no banco) ─
# Formato: IDs separados por vírgula.
# Após configurar via /config no Discord, estas variáveis são ignoradas.
#
# DEFAULT_ALLOWED_CHANNELS=1327836428524191765,1327836428524191766
# DEFAULT_IGNORED_VOICE_CHANNELS=1356045946743689236,1335352978986635468

# ── Moderação ──────────────────────────────────────────────────────────────────
# MODERATION_CONFIDENCE_THRESHOLD=0.80   # confiança mínima para deletar mensagem
# INTERVALO_ANALISE=60                   # segundos entre análises em lote
# TAMANHO_LOTE_MINIMO=10                 # min. de mensagens por lote de moderação
